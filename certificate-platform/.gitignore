venv/
ENV/
env/
.venv

# Node
node_modules/
npm-debug.log
yarn-error.log
package-lock.json

# IDEs
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Environment variables
.env
.env.local
.env.*.local

# Generated files
dist/
build/
*.log
generated_certificates/
uploads/

# Database
*.db
*.sqlite
*.sqlite3

# OS
.DS_Store
Thumbs.db
.windows-build-tools/

# Misc
.cache/
.pytest_cache/
htmlcov/
.coverage
.temp/
