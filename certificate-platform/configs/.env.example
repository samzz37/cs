# Backend Configuration
ENVIRONMENT=development

# Database
DATABASE_URL=mysql+pymysql://root:password@localhost:3306/CS
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40

# Security
SECRET_KEY=your-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Server
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=True
RELOAD=True

# File Upload
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=100

# Certificates
CERTIFICATE_OUTPUT_DIR=generated_certificates
CERTIFICATE_EXPIRY_DAYS=365

# SMS Configuration (configure with your SMS provider)
SMS_ENABLED=False
SMS_API_KEY=your-sms-api-key
SMS_API_URL=https://api.sms-provider.com
SMS_FROM_NUMBER=your-phone-number

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# CORS
CORS_ORIGINS=["http://localhost:3000", "http://localhost:5173"]
